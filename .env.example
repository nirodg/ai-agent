OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
PPLX_API_KEY=pplx-your_perplexity_api_key_here
OLLAMA_API_KEY=ollama-your_cloud_api_key_here
OLLAMA_INSECURE_SSL=true
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_api_key_here
LLM_PROVIDER=openrouter
LLM_TIMEOUT=30
LLM_MODEL=openai/gpt-oss-120b:free
PPLX_BASE_URL=https://api.perplexity.ai
OLLAMA_BASE_URL=https://ollama.com

# RAG embeddings & external connectors (optional)
# OPENAI_API_KEY (above) enables OpenAI embeddings; without it RAG falls back to a local model.
NOTION_API_KEY=secret_your_notion_integration_token_here
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
